FLASK_ENV=development
FLASK_APP=run.py
SECRET_KEY=mude-esta-chave-secreta-em-producao

# MySQL (produção)
DATABASE_URL=mysql+pymysql://usuario:senha@localhost:3306/camply

# SQLite (fallback desenvolvimento — usado automaticamente se DATABASE_URL não for configurado)
# DATABASE_URL=sqlite:///camply.db

# Config de e-mail (futuro)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=seu@email.com
MAIL_PASSWORD=sua-senha-de-app
